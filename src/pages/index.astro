---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Paniko Sandwich & Boneless en Bogotá: sandwiches urbanos, boneless, papas cargadas y domicilios por WhatsApp."
    />
    <link rel="icon" type="image/jpeg" href="/images/logo.jpeg" />
    <title>Paniko | Sandwich & Boneless Bogotá</title>
  </head>
  <body>
    <div class="loader" aria-live="polite" aria-label="Cargando Paniko">
      <div class="loader-card">
        <img src="/images/logo.jpeg" alt="Paniko" />
        <p>Preparando el pedido</p>
        <div class="loader-track"><span></span></div>
        <small>CUBANIK · V-KA · BONELESS</small>
      </div>
    </div>
    <div class="grain" aria-hidden="true"></div>
    <canvas id="panic-orb" aria-hidden="true"></canvas>
    <div class="scroll-rail" aria-hidden="true"><span></span></div>
    <div class="street-bg" aria-hidden="true">
      <span class="spray spray-a parallax-layer"></span>
      <span class="spray spray-b parallax-layer"></span>
      <span class="street-line parallax-layer"></span>
      <span class="panic-word parallax-layer">PANIKO</span>
    </div>

    <header class="site-header reveal-soft">
      <a class="brand" href="#top" aria-label="Paniko inicio"
        ><img src="/images/logo.jpeg" alt="Paniko Sandwich & Boneless" /></a
      >
      <div class="header-center">
        <span>Villa Alsacia · Bogotá</span>
        <nav aria-label="Navegación principal">
          <a href="#destacados">Top</a><a href="#menu">Menú</a><a
            href="#historia">Historia</a
          ><a href="#ubicacion">Mapa</a>
        </nav>
      </div>
      <a class="pill" href={orderUrl} target="_blank" rel="noopener noreferrer"
        ><span>WhatsApp</span><b>320 963 9322</b></a
      >
    </header>

    <main id="top">
      <section class="hero section-shell">
        <div class="hero-copy">
          <p class="eyebrow">Bogotá, Colombia · Sandwich & Boneless</p>
          <h1 class="hero-title split-title">PANIKO</h1>
          <p class="hero-subtitle">
            Sabores que no encuentras en otro lado. Recetas originales. Actitud
            Paniko.
          </p>
          <div class="hero-actions">
            <a
              class="button button-primary"
              href={orderUrl}
              target="_blank"
              rel="noopener noreferrer">Pedir por WhatsApp</a
            >
            <a class="button button-ghost" href="#menu">Ver menú</a>
          </div>
        </div>
        <div class="hero-card tilt-card">
          <img src="/images/cubanik.jpeg" alt="Sandwich Cubanik de Paniko" />
          <div class="hero-card-label">
            <span>Delicioso</span><strong>CUBANIK</strong>
          </div>
        </div>
      </section>

      <section class="ticker" aria-label="Productos Paniko">
        <div class="ticker-track">
          {
            [...tickerWords, ...tickerWords, ...tickerWords].map((word) => (
              <span>{word}</span>
            ))
          }
        </div>
      </section>

      <section class="ritual section-shell" aria-label="Cómo pedir en Paniko">
        <div class="ritual-copy reveal-up">
          <p class="eyebrow">Cómo pedir</p>
          <h2>Arma tu antojo</h2>
          <p>
            Esta sección te guía para convertir el scroll en pedido: eliges
            protagonista, salsa, combo y canal de domicilio.
          </p>
        </div>
        <div class="ritual-steps">
          <article class="ritual-card">
            <span>01</span><h3>Elige el fuerte</h3><p>
              Cubanik, V-KA, Meatball, Roast Beef, Parrik o boneless si vienes
              por crunch.
            </p>
          </article>
          <article class="ritual-card">
            <span>02</span><h3>Sube la salsa</h3><p>
              Vodka, casa, mostaza, pepinillos o la salsa que más combine con tu
              antojo.
            </p>
          </article>
          <article class="ritual-card">
            <span>03</span><h3>Hazlo combo</h3><p>
              Por $8.000 sumas papas francesas y limonada con refill o Coca Cola
              mini.
            </p>
          </article>
          <article class="ritual-card">
            <span>04</span><h3>Pide directo</h3><p>
              Toca “Pedir”, se abre WhatsApp con el producto y cerramos
              domicilio sin vueltas.
            </p>
          </article>
        </div>
      </section>

      <section class="section-shell" id="destacados">
        <div class="section-heading reveal-up">
          <p class="eyebrow">Los que ponen la calle a hablar</p><h2>
            PRODUCTOS ESPECIALES
          </h2>
        </div>
        <div class="featured-grid">
          {
            featured.map((item, index) => (
              <article
                class="product-card reveal-up"
                style={`--rotate:${index === 1 ? "1.5deg" : "-1.5deg"}`}
              >
                <img src={item.image} alt={item.name} loading="lazy" />
                <>
                  <p>{item.kicker}</p>
                  <h3>{item.name}</h3>
                  <span>{item.description}</span>
                </>
                <div>
                  <>
                    <strong>{item.price}</strong>
                    <a
                      href={`https://wa.me/${phone}?text=${encodeURIComponent(`Hola! Quiero pedir: ${item.name}`)}`}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Pedir
                    </a>
                  </>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <section class="menu-section section-shell" id="menu">
        <div class="menu-intro reveal-up">
          <div><p class="eyebrow">Nuestro menú</p><h2>El sabor habla</h2></div>
          <aside>
            <strong>Hazlo combo</strong><span
              >Papas francesas + limonada de la casa con refill o Coca Cola mini
              — todos los sandwiches</span
            ><b>+$ 8.000</b>
          </aside>
        </div>
        <div class="menu-board" data-menu-board>
          {
            menuGroups.map((group) => (
              <section class="menu-column reveal-up">
                <h3>{group.category}</h3>
                {group.items.map(([name, description, price]) => (
                  <article class="menu-item" data-menu-item>
                    <div>
                      <h4>{name}</h4>
                      <p>{description}</p>
                    </div>
                    <div class="menu-price">
                      <strong>{price}</strong>
                      <a
                        href={`https://wa.me/${phone}?text=${encodeURIComponent(`Hola! Quiero pedir: ${name}`)}`}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        Pedir
                      </a>
                    </div>
                  </article>
                ))}
              </section>
            ))
          }
        </div>
      </section>

      <section class="story" id="historia">
        <div class="story-image reveal-left">
          <img
            src="/images/cara.jpeg"
            alt="Ilustración urbana de Paniko"
            loading="lazy"
          />
        </div>
        <div class="story-copy reveal-up">
          <p class="eyebrow">Sobre Paniko</p><h2>Nacimos del pánico</h2>
          <p>
            Paniko nació de algo muy simple: el miedo a emprender. Después de
            años guardando ideas, recetas y mezclas en un cuaderno, convertimos
            esa obsesión por los sandwiches y el fast food americano en algo
            real.
          </p>
          <p>
            No buscamos hacer comida rápida aburrida: queremos que vengas, comas
            rico, te sientas cómodo y tengas ganas de volver.
          </p>
          <div class="values">
            <span>Salsas hechas en casa</span><span
              >Sandwiches con personalidad</span
            ><span>Identidad urbana</span>
          </div>
        </div>
      </section>

      <section class="testimonials section-shell">
        <div class="section-heading reveal-up">
          <p class="eyebrow">La calle habla</p><h2>Testimonios</h2>
        </div>
        <div class="quote-grid">
          {
            testimonials.map(([name, quote]) => (
              <figure class="quote-card reveal-up">
                <>
                  <blockquote>“{quote}”</blockquote>
                  <figcaption>{name}</figcaption>
                </>
              </figure>
            ))
          }
        </div>
      </section>

      <section class="order-section">
        <img
          src="/images/domicilio.jpeg"
          alt="Pedido Paniko para domicilio"
          loading="lazy"
        />
        <div class="order-copy reveal-up">
          <p class="eyebrow">¿Qué esperas?</p><h2>Pide ahora</h2><p>
            Escríbenos por WhatsApp y te armamos tu pedido. Rápido, directo, sin
            vueltas.
          </p><div class="hero-actions">
            <a
              class="button button-primary"
              href={orderUrl}
              target="_blank"
              rel="noopener noreferrer">Pedir por WhatsApp</a
            ><a
              class="button button-ghost"
              href="https://www.rappi.com.co"
              target="_blank"
              rel="noopener noreferrer">Rappi</a
            >
          </div>
        </div>
      </section>

      <section class="location section-shell" id="ubicacion">
        <div class="section-heading reveal-up">
          <p class="eyebrow">Encuéntranos</p><h2>Ubicación</h2>
        </div>
        <div class="location-grid">
          <article class="reveal-up">
            <h3>Dirección</h3><p>{address}</p>
          </article>
          <article class="reveal-up">
            <h3>Horarios</h3><p>
              Mar a Jue: 2PM - 9PM · Vie y Sáb: 2PM - 10:30PM · Festivos: 2PM -
              8PM · Lunes: Cerrado
            </p>
          </article>
          <article class="reveal-up">
            <h3>Contacto</h3><p>
              WhatsApp: 320 963 9322 · Instagram: @panikofood · TikTok:
              @panikosyb
            </p>
          </article>
        </div>
        <div class="map-stage reveal-up">
          <div class="map-copy">
            <p class="eyebrow">Villa Alsacia / Kennedy</p>
            <h3>Caiga con hambre. Nosotros ponemos el pánico.</h3>
            <p>
              Abre el mapa, calcula tu ruta o pide domicilio directo por
              WhatsApp. La sede queda en una zona fácil de ubicar para recogida
              y domicilios cercanos.
            </p>
            <div class="map-actions">
              <a
                class="button button-primary"
                href={directionsUrl}
                target="_blank"
                rel="noopener noreferrer">Cómo llegar</a
              >
              <a
                class="button button-ghost"
                href={orderUrl}
                target="_blank"
                rel="noopener noreferrer">Pedir domicilio</a
              >
            </div>
          </div>
          <div class="map-frame" data-map-parallax>
            <iframe
              title="Mapa de Paniko en Villa Alsacia Bogotá"
              src={mapUrl}
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
            <span class="map-pin" aria-hidden="true">PANIKO</span>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <img src="/images/logo.jpeg" alt="Paniko" />
      <p>Sabores que no encuentras en otro lado. Bogotá, Colombia.</p>
      <div>
        <a
          href="https://instagram.com/panikofood"
          target="_blank"
          rel="noopener noreferrer">Instagram</a
        ><a
          href="https://tiktok.com/@panikosyb"
          target="_blank"
          rel="noopener noreferrer">TikTok</a
        ><a href={orderUrl} target="_blank" rel="noopener noreferrer"
          >WhatsApp</a
        >
      </div>
      <small
        >© 2026 Paniko Sandwich & Boneless · Hecho con sabor en Bogotá</small
      >
    </footer>

    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      gsap.registerPlugin(ScrollTrigger);
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      function initMotion() {
        if (reduceMotion) {
          gsap.set(".loader", { autoAlpha: 0, display: "none" });
          gsap.set(".reveal-up, .reveal-left, .reveal-soft, .ritual-card", {
            autoAlpha: 1,
            x: 0,
            y: 0,
          });
          return;
        }

        gsap.defaults({ ease: "power3.out", duration: 0.9 });
        gsap.set(
          ".site-header, .split-title, .hero-subtitle, .hero-actions, .hero-card",
          { autoAlpha: 0 },
        );
        const intro = gsap.timeline({ defaults: { ease: "power3.out" } });
        intro
          .from(".loader-card", {
            y: 40,
            scale: 0.92,
            autoAlpha: 0,
            duration: 0.55,
          })
          .to(
            ".loader-track span",
            {
              scaleX: 1,
              transformOrigin: "left center",
              duration: 0.75,
              ease: "power2.inOut",
            },
            "<0.1",
          )
          .to(
            ".loader-card img",
            { rotate: -4, scale: 1.04, yoyo: true, repeat: 1, duration: 0.22 },
            "<0.28",
          )
          .to(".loader", {
            yPercent: -100,
            autoAlpha: 0,
            duration: 0.8,
            ease: "expo.inOut",
          })
          .set(".loader", { display: "none" })
          .fromTo(
            ".site-header",
            { autoAlpha: 0, y: -24 },
            { autoAlpha: 1, y: 0, duration: 0.55 },
            "-=0.15",
          )
          .fromTo(
            ".split-title",
            { autoAlpha: 0, yPercent: 18, scale: 0.94 },
            { autoAlpha: 1, yPercent: 0, scale: 1, duration: 0.85 },
            "<0.05",
          )
          .fromTo(
            ".hero-subtitle, .hero-actions",
            { autoAlpha: 0, y: 34 },
            { autoAlpha: 1, y: 0, stagger: 0.12, duration: 0.65 },
            "<0.18",
          )
          .fromTo(
            ".hero-card",
            { autoAlpha: 0, y: 80, rotation: 8, scale: 0.92 },
            { autoAlpha: 1, y: 0, rotation: 3, scale: 1, duration: 0.9 },
            "<0.05",
          );
        gsap.to(".scroll-rail span", {
          scaleY: 1,
          transformOrigin: "top center",
          ease: "none",
          scrollTrigger: {
            trigger: document.body,
            start: "top top",
            end: "bottom bottom",
            scrub: 0.5,
          },
        });
        gsap.to(".ticker-track", {
          xPercent: -16,
          ease: "none",
          scrollTrigger: {
            trigger: ".ticker",
            start: "top 92%",
            end: "bottom 8%",
            scrub: 3,
          },
        });

        gsap.utils.toArray<HTMLElement>(".reveal-up").forEach((element) => {
          gsap.from(element, {
            autoAlpha: 0,
            y: 54,
            scrollTrigger: {
              trigger: element,
              start: "top 84%",
              toggleActions: "play none none reverse",
            },
          });
        });
        gsap.utils.toArray<HTMLElement>(".reveal-left").forEach((element) => {
          gsap.from(element, {
            autoAlpha: 0,
            x: -70,
            rotate: -5,
            scrollTrigger: {
              trigger: element,
              start: "top 82%",
              toggleActions: "play none none reverse",
            },
          });
        });
        gsap.to(".tilt-card", {
          yPercent: -10,
          rotate: -1,
          ease: "none",
          scrollTrigger: {
            trigger: ".hero",
            start: "top top",
            end: "bottom top",
            scrub: 1,
          },
        });
        const ritualCards = gsap.utils.toArray<HTMLElement>(".ritual-card");
        gsap.set(ritualCards, { autoAlpha: 0.28, y: 60, scale: 0.92 });
        const ritualTimeline = gsap.timeline({
          scrollTrigger: {
            trigger: ".ritual",
            start: "top top",
            end: "+=1600",
            scrub: 1,
            pin: true,
          },
        });
        ritualTimeline
          .from(".ritual-copy h2", {
            xPercent: -12,
            autoAlpha: 0,
            duration: 0.7,
          })
          .to(
            ritualCards,
            { autoAlpha: 1, y: 0, scale: 1, stagger: 0.26, duration: 0.9 },
            "<0.15",
          )
          .to(
            ritualCards,
            {
              xPercent: (index) => (index % 2 === 0 ? -8 : 8),
              rotation: (index) => (index % 2 === 0 ? -2 : 2),
              stagger: 0.18,
              duration: 0.8,
            },
            "<0.35",
          )
          .to(".ritual", { "--ritual-glow": 1, duration: 0.6 }, "<");
        gsap.to(".featured-grid", {
          xPercent: -6,
          ease: "none",
          scrollTrigger: {
            trigger: "#destacados",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        const menuItems = gsap.utils.toArray<HTMLElement>("[data-menu-item]");
        gsap.set(".menu-column", { transformOrigin: "50% 0%" });
        const menuTimeline = gsap.timeline({
          scrollTrigger: {
            trigger: "#menu",
            start: "top 72%",
            end: "bottom 42%",
            toggleActions: "play none none none",
          },
        });
        menuTimeline
          .from(".menu-intro h2", {
            yPercent: 12,
            scale: 0.98,
            duration: 0.55,
          })
          .from(
            ".menu-intro aside",
            { x: 34, rotate: 1.4, duration: 0.5 },
            "<0.1",
          )
          .from(
            ".menu-column",
            { y: 44, rotateX: 7, stagger: 0.14, duration: 0.62 },
            "<0.12",
          )
          .from(
            menuItems,
            { x: -18, rotateX: -8, stagger: 0.045, duration: 0.36 },
            "-=0.35",
          );
        gsap.to(".menu-column:first-child", {
          yPercent: -4,
          ease: "none",
          scrollTrigger: {
            trigger: "#menu",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        gsap.to(".menu-column:last-child", {
          yPercent: 5,
          ease: "none",
          scrollTrigger: {
            trigger: "#menu",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        gsap.to(".story-image img", {
          scale: 1.12,
          yPercent: -8,
          ease: "none",
          scrollTrigger: {
            trigger: ".story",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        gsap.to(".order-section img", {
          scale: 1.1,
          xPercent: -4,
          ease: "none",
          scrollTrigger: {
            trigger: ".order-section",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        gsap.utils
          .toArray<HTMLElement>(".parallax-layer")
          .forEach((element, index) => {
            gsap.to(element, {
              yPercent: index % 2 === 0 ? -18 : 14,
              xPercent: index === 3 ? -8 : 0,
              rotate: index === 2 ? 5 : undefined,
              ease: "none",
              scrollTrigger: {
                trigger: document.body,
                start: "top top",
                end: "bottom bottom",
                scrub: 1.4,
              },
            });
          });
        gsap.utils
          .toArray<HTMLElement>(
            ".product-card, .quote-card, .location article, .menu-item",
          )
          .forEach((element) => {
            element.addEventListener("pointermove", (event) => {
              const bounds = element.getBoundingClientRect();
              const relX = (event.clientX - bounds.left) / bounds.width - 0.5;
              const relY = (event.clientY - bounds.top) / bounds.height - 0.5;
              gsap.to(element, {
                x: relX * 10,
                y: relY * 8,
                rotate: relX * 1.8,
                duration: 0.28,
                overwrite: "auto",
              });
            });
            element.addEventListener("pointerleave", () =>
              gsap.to(element, {
                x: 0,
                y: 0,
                rotate: 0,
                duration: 0.45,
                overwrite: "auto",
              }),
            );
          });
        gsap.from(".map-frame", {
          clipPath: "inset(18% 12% round 34px)",
          scale: 0.94,
          scrollTrigger: {
            trigger: ".map-stage",
            start: "top 78%",
            end: "center center",
            scrub: 0.8,
          },
        });
        gsap.to("[data-map-parallax]", {
          yPercent: -8,
          ease: "none",
          scrollTrigger: {
            trigger: ".location",
            start: "top bottom",
            end: "bottom top",
            scrub: 1,
          },
        });
        ScrollTrigger.refresh();
      }

      async function initThree() {
        const canvas = document.querySelector<HTMLCanvasElement>("#panic-orb");
        if (!canvas || reduceMotion) return;
        const activeCanvas = canvas;
        const THREE = await import("three");
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
        camera.position.z = 5;
        const renderer = new THREE.WebGLRenderer({
          canvas: activeCanvas,
          alpha: true,
          antialias: true,
        });
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));
        const group = new THREE.Group();
        scene.add(group);
        const geometry = new THREE.TorusKnotGeometry(1.08, 0.32, 180, 18);
        const material = new THREE.MeshStandardMaterial({
          color: "#8b00c7",
          roughness: 0.31,
          metalness: 0.18,
          emissive: "#250036",
          emissiveIntensity: 0.6,
        });
        const knot = new THREE.Mesh(geometry, material);
        group.add(knot);
        const dropGeometry = new THREE.SphereGeometry(0.085, 18, 18);
        const dropMaterials = ["#c8ff00", "#ff5b1a", "#fff8ee"].map(
          (color) =>
            new THREE.MeshStandardMaterial({
              color,
              roughness: 0.4,
              emissive: color,
              emissiveIntensity: 0.28,
            }),
        );
        const drops = Array.from({ length: 26 }, (_, index) => {
          const drop = new THREE.Mesh(
            dropGeometry,
            dropMaterials[index % dropMaterials.length],
          );
          const angle = (index / 26) * Math.PI * 2;
          const radius = 1.72 + (index % 5) * 0.11;
          drop.position.set(
            Math.cos(angle) * radius,
            Math.sin(angle * 1.7) * 0.42,
            Math.sin(angle) * radius,
          );
          drop.userData = {
            angle,
            radius,
            speed: 0.24 + (index % 6) * 0.025,
            lift: 0.28 + (index % 4) * 0.08,
          };
          group.add(drop);
          return drop;
        });
        scene.add(new THREE.AmbientLight("#fff8ee", 1.4));
        const light = new THREE.PointLight("#c8ff00", 22, 9);
        light.position.set(2.5, 2, 3);
        scene.add(light);
        const startedAt = performance.now();
        function resize() {
          const width = activeCanvas.clientWidth || 520;
          const height = activeCanvas.clientHeight || 520;
          renderer.setSize(width, height, false);
          camera.aspect = width / height;
          camera.updateProjectionMatrix();
        }
        function animate() {
          const elapsed = (performance.now() - startedAt) / 1000;
          knot.rotation.x = elapsed * 0.22;
          knot.rotation.y = elapsed * 0.34;
          group.rotation.z = Math.sin(elapsed * 0.23) * 0.16;
          drops.forEach((drop) => {
            const data = drop.userData as {
              angle: number;
              radius: number;
              speed: number;
              lift: number;
            };
            const angle = data.angle + elapsed * data.speed;
            drop.position.x = Math.cos(angle) * data.radius;
            drop.position.z = Math.sin(angle) * data.radius;
            drop.position.y = Math.sin(angle * 2.1 + elapsed) * data.lift;
            drop.scale.setScalar(
              0.75 + Math.sin(elapsed * 2 + data.angle) * 0.18,
            );
          });
          material.emissiveIntensity = 0.46 + Math.sin(elapsed * 1.7) * 0.16;
          renderer.render(scene, camera);
        }
        resize();
        renderer.setAnimationLoop(animate);
        window.addEventListener("resize", resize);
        window.addEventListener("beforeunload", () => {
          window.removeEventListener("resize", resize);
          renderer.setAnimationLoop(null);
          geometry.dispose();
          dropGeometry.dispose();
          dropMaterials.forEach((dropMaterial) => dropMaterial.dispose());
          material.dispose();
          renderer.dispose();
        });
      }

      initMotion();
      window.requestIdleCallback?.(() => void initThree()) ??
        window.setTimeout(() => void initThree(), 1);
    </script>
  </body>
